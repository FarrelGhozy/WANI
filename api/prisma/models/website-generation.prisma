model WebsiteGeneration {
  id           String   @id @default(uuid())
  ownerId      String
  slug         String
  status       String
  productCount Int      @default(0)
  message      String   @db.Text
  createdAt    DateTime @default(now())

  @@unique([ownerId, slug])
  @@index([ownerId, createdAt])
}
