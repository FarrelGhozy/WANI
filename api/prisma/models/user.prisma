model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  password             String
  role                 String    @default("admin")
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([email])
}
