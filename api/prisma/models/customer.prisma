model Customer {
  id          String   @id @default(uuid())
  ownerId     String
  phone       String
  name        String
  notes       String?
  totalOrders Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders        Order[]
  conversations Conversation[]

  @@unique([ownerId, phone])
  @@index([ownerId])
}
