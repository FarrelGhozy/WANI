# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=wani_api

# Server
PORT=3001
NODE_ENV=development

# Security
API_TOKEN=change-me-to-a-random-secret
JWT_SECRET=change-me-to-a-random-jwt-secret

# LLM (OpenRouter)
OPENROUTER_API_KEY=
LLM_MODEL=deepseek/deepseek-v4-flash:free
LLM_FALLBACK_MODEL=google/gemini-2.0-flash-exp:free
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# Guardrails
# Per-customer flood control (sliding windows)
RATE_LIMIT_SHORT_MAX=8
RATE_LIMIT_SHORT_WINDOW_MS=30000
RATE_LIMIT_LONG_MAX=60
RATE_LIMIT_LONG_WINDOW_MS=3600000
# Max inbound characters accepted from a single message (longer is truncated)
MAX_INPUT_CHARS=4000
# Max characters in an outbound reply
MAX_REPLY_CHARS=1500
# Daily store-wide LLM call budget (0 = unlimited)
DAILY_LLM_BUDGET=2000

# Multi-layer guardrails (3-tier injection detection + grounding)
# Tier 2: ML classifier (fast model via OpenRouter)
CLASSIFIER_ENABLED=true
CLASSIFIER_MODEL=google/gemini-2.0-flash-lite
# Tier 3: Deep LLM judge for SUSPICIOUS cases
JUDGE_ENABLED=true
JUDGE_MODEL=google/gemini-2.0-flash-lite
# Output grounding check (LLM-as-judge)
GROUNDING_CHECK_ENABLED=true
GROUNDING_MODEL=google/gemini-2.0-flash-lite

# Whatsapp Bot Settings
WABOT_DATABASE_URL=postgresql://postgres:your_password@localhost:5432/your_db_name
