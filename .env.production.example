# Database — ganti password!
DB_PASSWORD=ganti-ini-password-kuat

# JWT Secret — ganti!
JWT_SECRET=ganti-ini-random-string-panjang

# OpenRouter AI Key
OPENROUTER_API_KEY=sk-or-v1-your-key

# LLM Model (optional, ada default)
LLM_MODEL=opencode/deepseek-v4-flash-free

# Domain
API_HOST=api.wani.local
WEB_HOST=wani.local
LETSENCRYPT_EMAIL=admin@example.com

# Sentry (DSN dari dashboard Sentry → Projects → your project → Settings)
SENTRY_DSN=

# CORS
CORS_ORIGIN=https://wani.local

# Web (dibaca Next.js di build-time)
NEXT_PUBLIC_API_URL=http://api:3001
NEXT_PUBLIC_STORE_URL=https://wani.local
