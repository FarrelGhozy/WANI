---
import * as fs from "node:fs"

const store = JSON.parse(fs.readFileSync("src/data/store.json", "utf-8"))
const siteConfig = JSON.parse(fs.readFileSync("src/data/site-config.json", "utf-8"))

const { title, description } = Astro.props as {
  title?: string
  description?: string
}

const pageTitle = title
  ? `${title} | ${store.businessName}`
  : store.businessName
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description ?? `Official website ${store.businessName}`} />
    <meta name="theme-color" content={siteConfig.colors.primary} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description ?? `Official website ${store.businessName}`} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
    <style>
      :root {
        --color-primary: {siteConfig.colors.primary};
        --color-secondary: {siteConfig.colors.secondary};
      }
      .text-primary { color: var(--color-primary); }
      .bg-primary { background-color: var(--color-primary); }
      .hover\:bg-primary-dark:hover { background-color: color-mix(in srgb, var(--color-primary) 85%, black); }
      .bg-secondary { background-color: var(--color-secondary); }
      .hover\:bg-secondary-dark:hover { background-color: color-mix(in srgb, var(--color-secondary) 85%, black); }
      .border-primary { border-color: var(--color-primary); }
    </style>
  </head>
  <body class="bg-stone-50 text-stone-900 font-sans antialiased">
    <slot />
  </body>
</html>
