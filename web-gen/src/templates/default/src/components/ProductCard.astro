---
import * as fs from "node:fs"
const store = JSON.parse(fs.readFileSync("src/data/store.json", "utf-8"))
const siteConfig = JSON.parse(fs.readFileSync("src/data/site-config.json", "utf-8"))

export interface Props {
  product: {
    id: string
    name: string
    description: string | null
    price: number
    stock: number
    isAvailable: boolean
    imageUrl: string | null
  }
}

const { product } = Astro.props as Props

const fmt = new Intl.NumberFormat("id-ID")
const waMessage = (siteConfig.waOrderTemplate ?? "")
  .replace(/\{store\.businessName\}/g, store.businessName)
  .replace(/\{product\.name\}/g, product.name)
  .replace(/\{product\.price\}/g, `Rp ${fmt.format(product.price)}`)

const waUrl = `https://wa.me/${store.phone.replace(/[^0-9]/g, "")}?text=${encodeURIComponent(waMessage)}`

const p = siteConfig.colors?.primary ?? "#059669"
const s = siteConfig.colors?.secondary ?? "#f59e0b"
---

<div class="product-card">
  <div class="product-image">
    {product.imageUrl ? (
      <img src={product.imageUrl} alt={product.name} loading="lazy" class="product-img" />
    ) : (
      <div class="product-placeholder" style={`background: linear-gradient(135deg, ${p}15, ${s}20)`}>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width:3rem;height:3rem;opacity:0.3;color:var(--color-primary)">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
        </svg>
      </div>
    )}
    <span class={`product-badge ${product.isAvailable ? "product-badge--in" : "product-badge--out"}`}>
      {product.isAvailable ? "Tersedia" : "Habis"}
    </span>
  </div>
  <div class="product-body">
    <h3 class="product-name">{product.name}</h3>
    <p class="product-price">Rp {fmt.format(product.price)}</p>
    {product.description && (
      <p class="product-desc">{product.description}</p>
    )}
    <a href={waUrl} target="_blank" rel="noopener noreferrer" class="btn btn-wa product-wa-btn">
      <svg fill="currentColor" viewBox="0 0 24 24" style="width:1rem;height:1rem;">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Pesan via WhatsApp
    </a>
  </div>
</div>

<style>
  .product-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .product-card:hover .product-img {
    transform: scale(1.05);
  }
</style>
