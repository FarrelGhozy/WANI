---
import * as fs from "node:fs"
const store = JSON.parse(fs.readFileSync("src/data/store.json", "utf-8"))
const siteConfig = JSON.parse(fs.readFileSync("src/data/site-config.json", "utf-8"))

export interface Props {
  product: {
    id: string
    name: string
    description: string | null
    price: number
    stock: number
    isAvailable: boolean
    imageUrl: string | null
  }
}

const { product } = Astro.props as Props

const fmt = new Intl.NumberFormat("id-ID")
const waMessage = (siteConfig.waOrderTemplate ?? "")
  .replace(/\{store\.businessName\}/g, store.businessName)
  .replace(/\{product\.name\}/g, product.name)
  .replace(/\{product\.price\}/g, `Rp ${fmt.format(product.price)}`)

const waUrl = `https://wa.me/${store.phone.replace(/[^0-9]/g, "")}?text=${encodeURIComponent(waMessage)}`
---

<div class="bg-white rounded-xl border border-stone-200 shadow-sm overflow-hidden flex flex-col hover:shadow-md transition-shadow">
  <div class="aspect-[4/3] bg-stone-100 flex items-center justify-center overflow-hidden">
    {product.imageUrl
      ? <img src={product.imageUrl} alt={product.name} class="w-full h-full object-cover" loading="lazy" />
      : (
        <svg class="w-12 h-12 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      )
    }
  </div>
  <div class="p-4 flex flex-col flex-1">
    <h3 class="font-semibold text-stone-900 mb-1">{product.name}</h3>
    <p class="text-primary font-bold text-lg mb-1">Rp {fmt.format(product.price)}</p>
    {product.description && (
      <p class="text-stone-500 text-sm mb-3 line-clamp-2">{product.description}</p>
    )}
    <div class="mt-auto flex items-center justify-between">
      <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${product.stock > 0 ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700"}`}>
        {product.stock > 0 ? "Tersedia" : "Habis"}
      </span>
    </div>
    <a
      href={waUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 inline-flex items-center justify-center gap-2 bg-green-600 text-white text-sm font-semibold px-4 py-2.5 rounded-xl no-underline hover:bg-green-700 transition-colors"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Pesan via WhatsApp
    </a>
  </div>
</div>
