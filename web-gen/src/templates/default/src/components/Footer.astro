---
import * as fs from "node:fs"
const store = JSON.parse(fs.readFileSync("src/data/store.json", "utf-8"))
const siteConfig = JSON.parse(fs.readFileSync("src/data/site-config.json", "utf-8"))
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <h3 class="footer-heading">{store.businessName}</h3>
      <p class="footer-text">{siteConfig.about.description}</p>
    </div>
    <div>
      <h3 class="footer-heading">Menu</h3>
      <ul class="footer-links">
        <li><a href="/">Beranda</a></li>
        <li><a href="/produk/">Produk</a></li>
        <li><a href="/kontak/">Kontak</a></li>
      </ul>
    </div>
    <div>
      <h3 class="footer-heading">Kontak</h3>
      <ul class="footer-links">
        <li>{store.phone}</li>
        <li>{store.address}</li>
        <li>{store.businessHours}</li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    &copy; {new Date().getFullYear()} {store.businessName}. All rights reserved.
  </div>
</footer>
