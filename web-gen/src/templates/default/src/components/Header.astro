---
import * as fs from "node:fs"
const store = JSON.parse(fs.readFileSync("src/data/store.json", "utf-8"))
const siteConfig = JSON.parse(fs.readFileSync("src/data/site-config.json", "utf-8"))

const logoUrl = siteConfig.logoUrl ?? store.logoUrl ?? null

const path = Astro.url.pathname
const isActive = (href: string) => {
  const target = href.replace("./", "")
  if (!target) return !path.includes("/produk/") && !path.includes("/kontak/")
  return path.includes(target)
}
---

<header class="site-header" id="siteHeader">
  <nav class="site-nav">
    <a href="./" class="site-logo">
      {logoUrl ? (
        <img src={logoUrl} alt={store.businessName} class="site-logo-img" />
      ) : (
        <span class="site-logo-text">{store.businessName}</span>
      )}
    </a>
    <div class="nav-links">
      <a href="./" class={`nav-link${isActive("./") ? " nav-link--active" : ""}`}>Beranda</a>
      <a href="./produk/" class={`nav-link${isActive("./produk/") ? " nav-link--active" : ""}`}>Produk</a>
      <a href="./kontak/" class={`nav-link${isActive("./kontak/") ? " nav-link--active" : ""}`}>Kontak</a>
    </div>
    <button class="nav-toggle" id="navToggle" aria-label="Menu">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    <div class="mobile-menu" id="mobileMenu">
      <a href="./" class={`nav-link${isActive("./") ? " nav-link--active" : ""}`}>Beranda</a>
      <a href="./produk/" class={`nav-link${isActive("./produk/") ? " nav-link--active" : ""}`}>Produk</a>
      <a href="./kontak/" class={`nav-link${isActive("./kontak/") ? " nav-link--active" : ""}`}>Kontak</a>
    </div>
  </nav>
</header>

<style>
  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }
  .site-logo-img {
    height: 2.25rem;
    width: auto;
    border-radius: 0.375rem;
    object-fit: contain;
  }
  .site-logo-text {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-primary);
  }
</style>

<script>
  document.getElementById("navToggle")?.addEventListener("click", () => {
    document.getElementById("mobileMenu")?.classList.toggle("open")
  })
  window.addEventListener("scroll", () => {
    const header = document.getElementById("siteHeader")
    if (header) {
      header.classList.toggle("site-header--scrolled", window.scrollY > 50)
    }
  })
</script>
