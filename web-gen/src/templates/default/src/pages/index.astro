---
import * as fs from "node:fs"
import BaseLayout from "../layouts/BaseLayout.astro"
import Header from "../components/Header.astro"
import HeroSection from "../components/HeroSection.astro"
import AboutSection from "../components/AboutSection.astro"
import ProductCard from "../components/ProductCard.astro"
import ContactInfo from "../components/ContactInfo.astro"
import Footer from "../components/Footer.astro"
import WaButton from "../components/WaButton.astro"

const store = JSON.parse(fs.readFileSync("src/data/store.json", "utf-8"))
const products = JSON.parse(fs.readFileSync("src/data/products.json", "utf-8"))
const siteConfig = JSON.parse(fs.readFileSync("src/data/site-config.json", "utf-8"))

const featuredProducts = products.slice(0, 6)
---

<BaseLayout>
  <Header />
  <HeroSection />
  <AboutSection />

  {featuredProducts.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Produk Unggulan</h2>
        <div class="product-grid">
          {featuredProducts.map((product) => <ProductCard product={product} />)}
        </div>
        {products.length > 6 && (
          <div style="text-align:center; margin-top: 2rem;">
            <a href="./produk/" class="btn btn-hero btn-hero--primary" style="display:inline-block;">
              Lihat Semua Produk
            </a>
          </div>
        )}
      </div>
    </section>
  )}

  <ContactInfo />
  <Footer />
  <WaButton />
</BaseLayout>
