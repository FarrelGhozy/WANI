---
import * as fs from "node:fs"
import BaseLayout from "../layouts/BaseLayout.astro"
import Header from "../components/Header.astro"
import ContactInfo from "../components/ContactInfo.astro"
import Footer from "../components/Footer.astro"
import WaButton from "../components/WaButton.astro"

const store = JSON.parse(fs.readFileSync("src/data/store.json", "utf-8"))
---

<BaseLayout title="Kontak" description="Hubungi {store.businessName}">
  <Header />
  <main class="min-h-[60vh] flex items-center">
    <ContactInfo />
  </main>
  <Footer />
  <WaButton />
</BaseLayout>
