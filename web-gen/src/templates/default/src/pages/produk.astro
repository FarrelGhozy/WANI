---
import * as fs from "node:fs"
import BaseLayout from "../layouts/BaseLayout.astro"
import Header from "../components/Header.astro"
import ProductCard from "../components/ProductCard.astro"
import Footer from "../components/Footer.astro"
import WaButton from "../components/WaButton.astro"

const store = JSON.parse(fs.readFileSync("src/data/store.json", "utf-8"))
const products = JSON.parse(fs.readFileSync("src/data/products.json", "utf-8"))
const availableProducts = products.filter((p: { isAvailable: boolean }) => p.isAvailable)
---

<BaseLayout title="Produk" description={`Katalog produk ${store.businessName}`}>
  <Header />
  <section class="section">
    <div class="container">
      <h1 class="section-title" style="margin-bottom: .5rem;">Produk Kami</h1>
      <p class="text-muted text-center" style="margin-bottom: 2rem;">
        Menampilkan {availableProducts.length} produk tersedia
      </p>

      {availableProducts.length > 0
        ? (
          <div class="product-grid">
            {availableProducts.map((product) => <ProductCard product={product} />)}
          </div>
        )
        : (
          <div style="text-align:center; padding: 4rem 0;">
            <p class="text-muted" style="font-size: 1.125rem;">Belum ada produk tersedia saat ini.</p>
          </div>
        )
      }
    </div>
  </section>
  <Footer />
  <WaButton />
</BaseLayout>
