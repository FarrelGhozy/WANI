# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_PASSWORD=change-me
DATABASE_USER=postgres
DATABASE_HOST=db
DATABASE_PORT=5432

# ── API ─────────────────────────────────────────────────
DATABASE_NAME_API=wani_api
API_PORT=3001
API_TOKEN=change-me-to-a-random-secret
# WABOT_DATABASE_URL=postgresql://user:pass@db:5432/wa_bot  # auto-built from vars above, only override if different
JWT_SECRET=change-me-to-a-random-jwt-secret

# ── WA Bot ──────────────────────────────────────────────
DATABASE_NAME_BOT=wa_bot
API_URL=http://api:3001

# ── OpenRouter / LLM ────────────────────────────────────
OPENROUTER_API_KEY=
LLM_MODEL=opencode/deepseek-v4-flash-free
LLM_FALLBACK_MODEL=google/gemini-2.0-flash-exp:free
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# ── Guardrails ──────────────────────────────────────────
RATE_LIMIT_SHORT_MAX=8
RATE_LIMIT_SHORT_WINDOW_MS=30000
RATE_LIMIT_LONG_MAX=60
RATE_LIMIT_LONG_WINDOW_MS=3600000
MAX_INPUT_CHARS=4000
MAX_REPLY_CHARS=1500
DAILY_LLM_BUDGET=2000
CLASSIFIER_ENABLED=true
CLASSIFIER_MODEL=google/gemini-2.0-flash-lite
JUDGE_ENABLED=true
JUDGE_MODEL=google/gemini-2.0-flash-lite
GROUNDING_CHECK_ENABLED=true
GROUNDING_MODEL=google/gemini-2.0-flash-lite

# ── Dashboard ───────────────────────────────────────────
VITE_API_URL=http://api:3001

# ── Web-Gen / Astro ─────────────────────────────────────
ASTRO_TELEMETRY_DISABLED=1
