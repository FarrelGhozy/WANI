{
  "name": "wani",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "version": "0.1.0",
  "description": "WANI — WA Niaga untuk UMKM. Omnichannel platform: WhatsApp Bot + Dashboard + Auto-Generated Web Store.",
  "type": "module",
  "scripts": {
    "dev": "pnpm run --parallel dev:api dev:web",
    "dev:api": "pnpm --filter @wani/api dev",
    "dev:web": "pnpm --filter @wani/web dev",
    "build": "pnpm run --parallel build",
    "build:api": "pnpm --filter @wani/api build",
    "build:web": "pnpm --filter @wani/web build",
    "start:api": "pnpm --filter @wani/api start",
    "start:web": "pnpm --filter @wani/web start",
    "test": "pnpm run --parallel test",
    "lint": "pnpm run --parallel lint",
    "db:generate": "pnpm --filter @wani/database db:generate",
    "db:migrate": "pnpm --filter @wani/database db:migrate",
    "db:push": "pnpm --filter @wani/database db:push",
    "db:studio": "pnpm --filter @wani/database db:studio",
    "db:seed": "pnpm --filter @wani/database db:seed",
    "docker:dev": "docker compose up",
    "docker:dev:build": "docker compose up --build",
    "docker:dev:down": "docker compose down",
    "docker:dev:db": "docker compose up postgres -d",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:build": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
